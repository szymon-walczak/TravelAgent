sequenceDiagram
    actor User
    participant CLI as cli.py
    participant Retry as RetryMiddleware
    participant Agent as travel_agent<br/>(pydantic-ai)
    participant Gemini as Gemini 2.5-flash-lite<br/>(Google API)
    participant Routes as get_detailed_routes
    participant SerpApi as SerpApi<br/>(Google Maps)
    participant PKP as get_pkp_ticket_price
    participant RAGChain as LangChain RAG Chain
    participant TrainDB as ChromaDB<br/>chroma_db-train
    participant CarTool as get_vehicle_consumption
    participant CarDB as ChromaDB<br/>chroma_db-vehicles
    participant Verify as verify_recommendation

    User->>CLI: "Compare car vs train from Warsaw to Kraków for 2 people"
    CLI->>Retry: invoke_with_retry_async(travel_agent.run)
    Retry->>Agent: run(query)
    Agent->>Gemini: system_prompt + query

    Note over Agent,Gemini: Agent decides which tools to call

    Agent->>Routes: get_detailed_routes("Warsaw", "Kraków")
    Routes->>SerpApi: GET google_maps_directions
    SerpApi-->>Routes: driving & transit routes + distances
    Routes-->>Agent: [{mode, dist_meters, duration, formatted_distance}, ...]

    Agent->>PKP: get_pkp_ticket_price(distance_km)
    PKP->>RAGChain: invoke({"input": "price for ~300km?"})
    RAGChain->>TrainDB: similarity_search k=3
    TrainDB-->>RAGChain: relevant price chunks
    RAGChain->>Gemini: generate answer from chunks
    Gemini-->>RAGChain: "~49 PLN"
    RAGChain-->>PKP: answer string
    PKP-->>Agent: "~49 PLN per person"

    Agent->>CarTool: get_vehicle_consumption("Toyota Corolla 2020")
    CarTool->>CarDB: similarity_search k=1
    alt car found in ChromaDB
        CarDB-->>CarTool: VehicleSpec (l_100km_*)
    else not found – LLM fallback
        CarTool->>Gemini: estimate fuel consumption
        Gemini-->>CarTool: VehicleSpec (source: LLM Estimation)
    end
    CarTool-->>Agent: VehicleSpec

    Note over Agent,Gemini: Agent calculates costs, drafts TravelResponse

    Agent->>Verify: verify_recommendation(raw_routes, TravelResponse)
    Note over Verify: Validates car cost within 2–20 L/100km range<br/>Validates train cost vs distance norms
    alt verification passed
        Verify-->>Agent: "✅ Verification Passed."
    else out of bounds
        Verify-->>Agent: "⚠️ Verification Warning: ..."
        Agent->>Gemini: recalculate with warning context
    end

    Agent-->>Retry: TravelResponse (structured output)
    Retry-->>CLI: TravelResponse
    CLI-->>User: Recommendation + cost breakdown
